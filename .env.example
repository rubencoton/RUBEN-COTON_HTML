# RUBEN COTON Email Builder — variables de entorno

# Cascada IA: Ollama (local PC) → Gemini (cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Acceso protegido (modo VPS público). Si vacío, escucha solo en 127.0.0.1.
AUTH_USER=ruben
AUTH_PASSWORD=

# Puerto (Coolify lo gestiona via PORT env)
PORT=8090
